# Google Gemini (free tier) — used for both LLM and embeddings
GOOGLE_API_KEY=

# Pinecone (serverless free tier)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=ma-dd-analyzer

# Embedding model (Google gemini-embedding-001, 3072-dim)
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=3072

# Local embeddings (optional, open source; avoids API quotas)
# To use:
#   EMBEDDING_PROVIDER=local
#   LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
#   EMBEDDING_DIMENSION=384
# Note: Pinecone index dimension MUST match the model dimension.
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM settings
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.0

# Retrieval settings
RETRIEVAL_TOP_K=5
CONFIDENCE_THRESHOLD=0.75
SECTION_BOOST_WEIGHT=0.2

# Chunking settings
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# LangSmith tracing (sign up at smith.langchain.com — free tier)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=ma-dd-analyzer

# MLflow experiment tracking
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=dd-analyzer-eval
